# Frontend Environment Variables
# These variables are prefixed with NEXT_PUBLIC_ so they're exposed to the browser
# Set these in your Vercel dashboard under Environment Variables

# Backend API URL (set this after deploying backend to Railway)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Frontend URL (set this after deploying to Vercel)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Analytics (optional)
NEXT_PUBLIC_ANALYTICS_ID=

# Feature Flags (optional)
NEXT_PUBLIC_ENABLE_BETA_FEATURES=false
